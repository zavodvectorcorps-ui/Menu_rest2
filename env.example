# === ОБЯЗАТЕЛЬНЫЕ ===
# Ваш домен (например: rest-menu.by)
DOMAIN=rest-menu.by

# URL бэкенда для фронтенда (с https://)
REACT_APP_BACKEND_URL=https://rest-menu.by

# JWT секрет (сгенерируйте: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Emergent LLM Key — для AI-перевода меню на английский (Settings → Переводы).
# Получить: https://app.emergent.sh → Profile → Universal Key.
# Без него кнопка «Перевести меню» вернёт пустые переводы (в логах:
# "translate_ru_to_en: EMERGENT_LLM_KEY is not set").
EMERGENT_LLM_KEY=sk-emergent-fD66246F32fEc2eE9E

# === ОПЦИОНАЛЬНЫЕ ===
# CORS origins (по умолчанию *)
CORS_ORIGINS=https://rest-menu.by

# MongoDB (по умолчанию — локальный контейнер)
# Если MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/restaurant_app
# MONGO_URL=mongodb://mongo:27017
# DB_NAME=restaurant_app
